# Copy this file to `.env` and fill with your Shiprocket credentials locally.
# Never commit real credentials.

PORT=3002

# Shiprocket Credentials
SHIPROCKET_EMAIL=your_shiprocket_email
SHIPROCKET_PASSWORD=your_shiprocket_password
SHIPROCKET_CHANNEL_ID=your_shiprocket_channel_id

# PostgreSQL Database
DATABASE_URL=postgresql://username:password@localhost:5432/shipping_service

# RabbitMQ
RABBITMQ_URL=amqp://localhost

# Orchestrator Integration
# POST /shipping/create-order
# GET  /shipping/track/:awb
# POST /shipping/cancel
# POST /shipping/serviceability